# =============================================================
# 코리너스 웹사이트 · 어드민 (koreaners.co) 환경변수 예시
# =============================================================
# - 실제 값은 .env.local 에 넣고, .env.local 은 절대 커밋하지 마세요.
# - 배포 환경변수의 진짜 기준(SoT)은 Vercel → Settings → Environment
#   Variables 입니다. 로컬 셋업은 `vercel env pull` 로 실제 값을 받는 게
#   가장 정확합니다. 이 파일은 "무엇을·왜 넣는지"의 지도입니다.
# - 표기: [공개] = 브라우저 노출(NEXT_PUBLIC_ 접두, 비밀 아님) /
#         [서버] = 서버 전용 비밀(절대 NEXT_PUBLIC_ 로 만들지 말 것) /
#         (선택) = 없어도 코드에 폴백이 있음.
# =============================================================

# ── Supabase ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co   # [공개] 프로젝트 URL (ref fbnatppygeqvlrjhcfez)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key                 # [공개] anon 키
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key             # [서버] 전권·RLS 우회. 어드민 sync 전용

# ── Notion 토큰 (통합이 2개입니다) ───────────────────────────
NOTION_TOKEN=your-main-notion-integration-token             # [서버] 메인 통합 — 문의·블로그·크리에이터·포트폴리오 공용
NOTION_CAREERS_TOKEN=your-careers-notion-integration-token  # [서버] 채용 전용 별도 통합(메인과 다른 앱)

# ── Notion DB / DataSource ID ────────────────────────────────
# ⚠ 크리에이터 DB가 2개이고 방향이 반대라 가장 헷갈립니다:
NOTION_DATABASE_ID=your-inquiries-db-id            # [서버] 문의(inquiries) 적재            (app/api/notion)
NOTION_BLOG_DB_ID=your-blog-db-id                  # [서버] 블로그
NOTION_PORTFOLIO_DB_ID=your-portfolio-db-id        # [서버] 포트폴리오
NOTION_CREATOR_DB_ID=your-creator-inbox-db-id      # [서버] 크리에이터 "지원 인박스" — 새 지원을 여기에 씀   (app/api/creator-application)
NOTION_CREATOR_LIST_DB_ID=your-creator-roster-id   # [서버] 크리에이터 "공개 로스터" — 여기서 읽어 /creator 발행 (app/api/sync/creators)
NOTION_CAREERS_DATASOURCE_ID=your-careers-ds-id    # [서버] 채용 공고 data source (코드는 DATABASE_ID 아니라 이 DATASOURCE_ID 를 씀)

# ── 동기화 보호 ──────────────────────────────────────────────
SYNC_SECRET=your-sync-secret                       # [서버] /api/sync/* 호출 인증 시크릿

# ── 분석 · 픽셀 ──────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX                      # [공개] GA4
NEXT_PUBLIC_FB_PIXEL_ID=your-fb-pixel-id            # [공개] Meta 픽셀(브라우저)
META_CAPI_ACCESS_TOKEN=your-capi-token             # [서버] Meta 전환 API(서버 이벤트 전송)
NEXT_PUBLIC_CHANNELIO_PLUGIN_KEY=                  # [공개](선택) 채널톡 플러그인 키. 없으면 /consult 위젯 미렌더

# ── 알림 (Slack Incoming Webhook) ────────────────────────────
SLACK_WEBHOOK_INQUIRIES=https://hooks.slack.com/services/...   # [서버] 신규 문의 알림
SLACK_WEBHOOK_CREATORS=https://hooks.slack.com/services/...    # [서버] 크리에이터 지원 알림

# ── 프로젝트 시트 동기화 (어드민 대시보드용) ─────────────────
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}     # [서버] 구글 서비스계정 JSON 한 줄. Sheets 읽기
GOOGLE_SHEETS_PROJECT_ID=your-source-spreadsheet-id           # [서버] 소스 스프레드시트 ID

# ── 사이트 URL (선택 — 없으면 koreaners.co 폴백) ─────────────
NEXT_PUBLIC_APP_URL=https://koreaners.co           # [공개](선택)
NEXT_PUBLIC_SITE_URL=https://koreaners.co          # [공개](선택)

# ── Vercel 자동 주입 (직접 설정하지 마세요) ──────────────────
# VERCEL_OIDC_TOKEN  — Vercel 런타임 자동 주입
# NODE_ENV           — 프레임워크 자동 설정

# ── (선택·미도입) Rate limit 분산 저장소 ─────────────────────
# 프로덕션 권장이나 아직 미도입(현재 in-memory). 도입 시 주석 해제:
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxx

# ── ⚠ 이 레포에서 쓰지 않는 변수 (설정 불필요) ───────────────
# .env.local 에 남아 있을 수 있으나 이 웹앱 코드는 참조하지 않습니다:
#   ANTHROPIC_API_KEY          — 이 레포 코드 미참조(용도 불명). 넣지 말 것
#   KOREA_EXIM_API_KEY         — 환율은 별도 work-scripts 잡이 사용, 이 앱 아님
#   NOTION_PROJECT_DB_ID       — 구 기획 잔재. 현재 프로젝트는 Google Sheets 동기화로 대체
#   NOTION_CAREERS_DATABASE_ID — 코드는 NOTION_CAREERS_DATASOURCE_ID 를 씀. 이 키는 미사용

# ── 참고 ─────────────────────────────────────────────────────
# - 도메인 변경 시 문의 API CORS 허용 목록은 app/api/notion/route.ts 의
#   ALLOWED_ORIGINS 에 등록(koreaners.co·www·localhost·*.vercel.app 은 이미 포함).
